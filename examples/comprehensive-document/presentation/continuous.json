{
  "version": "0.1",
  "type": "continuous",
  "defaults": {
    "fontFamily": "system-ui, -apple-system, sans-serif",
    "fontSize": "16px",
    "lineHeight": 1.6,
    "maxWidth": "80ch",
    "margin": "2rem auto",
    "padding": "1rem"
  },
  "styles": {
    "heading1": {
      "fontSize": "2.5rem",
      "fontWeight": "bold",
      "marginTop": "2rem",
      "marginBottom": "1rem"
    },
    "heading2": {
      "fontSize": "2rem",
      "fontWeight": "bold",
      "marginTop": "1.5rem",
      "marginBottom": "0.75rem"
    },
    "heading3": {
      "fontSize": "1.5rem",
      "fontWeight": "bold",
      "marginTop": "1.25rem",
      "marginBottom": "0.5rem"
    },
    "paragraph": {
      "marginBottom": "1rem"
    },
    "codeBlock": {
      "fontFamily": "ui-monospace, monospace",
      "fontSize": "0.9rem",
      "backgroundColor": "#f5f5f5",
      "paddingTop": "1rem",
      "paddingRight": "1rem",
      "paddingBottom": "1rem",
      "paddingLeft": "1rem",
      "borderRadius": "4px",
      "overflow": "auto"
    },
    "blockquote": {
      "borderLeft": "4px solid #ccc",
      "paddingLeft": "1rem",
      "marginLeft": "0",
      "fontStyle": "italic"
    },
    "table": {
      "borderCollapse": "collapse",
      "width": "100%",
      "marginBottom": "1rem"
    },
    "tableCell": {
      "borderWidth": "1px",
      "borderStyle": "solid",
      "borderColor": "#ddd",
      "paddingTop": "0.5rem",
      "paddingRight": "0.5rem",
      "paddingBottom": "0.5rem",
      "paddingLeft": "0.5rem"
    },
    "horizontalRule": {
      "borderStyle": "none",
      "borderTop": "1px solid #ccc",
      "marginTop": "2rem",
      "marginBottom": "2rem"
    },
    "math": {
      "textAlign": "center",
      "marginTop": "1.5rem",
      "marginBottom": "1.5rem"
    },
    "figure": {
      "marginTop": "1.5rem",
      "marginBottom": "1.5rem",
      "textAlign": "center"
    },
    "figcaption": {
      "fontStyle": "italic",
      "fontSize": "0.9rem",
      "marginTop": "0.5rem"
    },
    "measurement": {
      "fontFamily": "ui-monospace, monospace",
      "backgroundColor": "#f0f8ff",
      "paddingTop": "0.25rem",
      "paddingRight": "0.5rem",
      "paddingBottom": "0.25rem",
      "paddingLeft": "0.5rem",
      "borderRadius": "2px"
    },
    "signature": {
      "borderWidth": "1px",
      "borderStyle": "dashed",
      "borderColor": "#999",
      "paddingTop": "1rem",
      "paddingRight": "1rem",
      "paddingBottom": "1rem",
      "paddingLeft": "1rem",
      "marginTop": "1rem",
      "marginBottom": "1rem",
      "backgroundColor": "#fafafa"
    },
    "definitionList": {
      "marginBottom": "1rem"
    },
    "definitionTerm": {
      "fontWeight": "bold",
      "marginTop": "0.5rem"
    },
    "definitionDescription": {
      "marginLeft": "1.5rem",
      "marginBottom": "0.5rem"
    }
  }
}
