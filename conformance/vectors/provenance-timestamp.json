  "suite": "cdx-conformance",
  "specVersion": "0.1",
  "kind": "provenance-timestamp",
  "clause": "Provenance and Lineage section 6",
  "description": "Provenance timestamp binding: which member each type keys on, and the untagged section 6.5 aggregated Merkle fold.",
  "oracle": "Expected values were computed by an INDEPENDENT Python oracle (json + hashlib), not by the library under test, so a serializer or folding bug is caught rather than snapshotted.",
  "requires": [
    "provenance"
  ],
  "vectors": [
    {
      "name": "rfc3161-bound",
      "description": "An rfc3161 entry keys on its `hash` member; equal to the documentId, so the timestamp attests this document.",
      "documentId": "sha256:1111111111111111111111111111111111111111111111111111111111111111",
      "timestamp": {
        "type": "rfc3161",
        "time": "2025-01-15T10:00:00Z",
        "hash": "sha256:1111111111111111111111111111111111111111111111111111111111111111",
        "token": "MIIEjDAVBgkqhkiG9w0BCQUxCDAGBgQBMjM0",
        "authority": "https://timestamp.digicert.com"
      },
      "expected": {
        "boundToDocument": true,
        "leaf": "sha256:1111111111111111111111111111111111111111111111111111111111111111",
        "problemsEmpty": true
      }
    },
    {
      "name": "rfc3161-mismatch",
      "description": "An rfc3161 `hash` that is not the documentId does not attest this document and is not bound.",
