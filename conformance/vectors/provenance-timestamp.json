    {
      "name": "aggregated-hash-decoy-rejected",
      "description": "The fail-open guard: the top-level `hash` equals the documentId while `proof.documentHash` does NOT. The Merkle path still verifies, so a verifier keying only on `hash` would wrongly accept an entry anchoring a different leaf. Binding MUST key on the leaf.",
      "documentId": "sha256:1111111111111111111111111111111111111111111111111111111111111111",
      "timestamp": {
        "type": "aggregated",
        "time": "2025-01-15T10:10:00Z",
        "hash": "sha256:1111111111111111111111111111111111111111111111111111111111111111",
        "proof": {
          "documentHash": "sha256:2222222222222222222222222222222222222222222222222222222222222222",
          "path": [
            {
              "position": "right",
              "hash": "sha256:3333333333333333333333333333333333333333333333333333333333333333"
            }
          ]
        },
        "merkleRoot": "sha256:c8e5ff41fdd4ca636d8fa244e9600532589f5023c7c17c3e02f7e0fa743e7fe1",
        "anchor": {
          "chain": "bitcoin",
          "blockHeight": 880000,
          "txId": "f4184fc596403b9d638783cf57adfe4c75c605f6356fbc91338530e9831e9e16"
        }
      },
