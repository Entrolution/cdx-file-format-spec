    "measurement": {
      "allOf": [
        { "$ref": "#/$defs/blockBase" },
        {
          "type": "object",
          "required": ["type", "value", "display"],
          "properties": {
            "type": { "const": "measurement" },
            "value": {
              "type": "number",
              "description": "Numeric value"
            },
            "uncertainty": {
              "type": "number",
              "description": "Measurement uncertainty"
            },
            "uncertaintyNotation": {
              "type": "string",
              "enum": ["parenthetical", "plusminus", "range", "percent"],
              "description": "How uncertainty is displayed"
            },
            "exponent": {
              "type": "integer",
              "description": "Power of 10 for scientific notation"
            },
            "unit": {
              "type": "string",
              "description": "Unit of measurement"
            },
            "display": {
              "type": "string",
              "description": "Human-readable display string. Presentational and out-of-hash: stripped before hashing (Document Hashing 4.3.1) and attested by no signature, so a renderer MUST NOT present it as authoritative — the hashed value/unit are the authoritative quantity and the display SHOULD be regenerated from them (Renderer Safety 6)."
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "signature": {
      "allOf": [
        { "$ref": "#/$defs/blockBase" },
        {
          "type": "object",
          "required": ["type", "signatureType"],
          "properties": {
            "type": { "const": "signature" },
            "signatureType": {
              "type": "string",
              "enum": ["handwritten", "digital", "electronic", "stamp"],
              "description": "Type of signature"
            },
            "image": {
              "$ref": "https://cdx.dev/schemas/anchor.schema.json#/$defs/safeImageUri",
              "description": "Signature image source — an archive-relative path, or an external reference resolved at render time when `external` is true. Constrained to safe image schemes (see the Renderer Safety core specification, section 2.2): https/relative or a data:image raster payload, excluding data:image/svg+xml (active content) and javascript:/data:text."
            },
            "signer": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
                  "description": "Signer's full name"
                },
                "title": {
                  "type": "string",
                  "description": "Professional title"
                },
                "organization": {
                  "type": "string",
                  "description": "Organization name"
                },
                "email": {
                  "type": "string",
                  "description": "Contact email"
                },
                "id": {
                  "type": "string",
                  "description": "Unique identifier"
                }
              },
              "additionalProperties": false
            },
            "timestamp": {
              "type": "string",
              "format": "date-time",
              "description": "ISO 8601 timestamp"
            },
            "purpose": {
              "type": "string",
              "enum": ["certification", "approval", "witness", "acknowledgment", "authorship"],
              "description": "Purpose of the signature"
            },
            "digitalSignatureRef": {
              "type": "string",
              "description": "Reference to cryptographic signature"
            },
            "external": {
              "type": "boolean",
              "description": "When true, `image` is an external reference resolved at render time and left verbatim in the canonical content (Document Hashing section 4.3.1)"
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "svg": {
      "allOf": [
        { "$ref": "#/$defs/blockBase" },
        {
          "type": "object",
          "required": ["type", "alt"],
          "properties": {
            "type": { "const": "svg" },
            "src": {
              "$ref": "https://cdx.dev/schemas/anchor.schema.json#/$defs/safeImageUri",
              "description": "Path to SVG file. Constrained to safe schemes (see the Renderer Safety core specification); the file's rendered SVG content is additionally subject to the sanitize-all-SVG rule (Renderer Safety section 3.1)."
            },
            "content": {
              "type": "string",
              "description": "Inline SVG content"
            },
            "alt": {
              "type": "string",
              "description": "Alternative text"
            },
            "title": {
              "type": "string",
              "description": "Title/caption"
            },
            "width": {
              "type": "integer",
              "minimum": 1,
              "description": "Display width in pixels"
            },
            "height": {
              "type": "integer",
              "minimum": 1,
              "description": "Display height in pixels"
            },
            "external": {
              "type": "boolean",
              "description": "When true, `src` is an external reference resolved at render time and left verbatim in the canonical content (Document Hashing section 4.3.1)"
            }
          },
          "oneOf": [
            { "required": ["src"] },
            { "required": ["content"] }
          ]
        }
      ],
      "unevaluatedProperties": false
    },
