      "unevaluatedProperties": false
    },
    "tableRow": {
      "allOf": [
        { "$ref": "#/$defs/blockBase" },
        {
          "type": "object",
          "required": ["type", "children"],
          "properties": {
            "type": { "const": "tableRow" },
