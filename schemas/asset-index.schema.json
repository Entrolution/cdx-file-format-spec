{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cdx.dev/schemas/asset-index.schema.json",
  "title": "Asset Index",
  "description": "Schema for asset index files in a CDX document",
  "type": "object",
  "required": ["version", "assets"],
  "properties": {
    "version": {
      "type": "string",
      "description": "Asset index version",
      "pattern": "^\\d+\\.\\d+$"
    },
    "families": {
      "type": "array",
      "description": "Font families (for font assets only)",
      "items": {
        "$ref": "#/$defs/fontFamily"
      }
    },
    "assets": {
      "type": "array",
      "description": "Array of asset entries",
      "items": {
        "$ref": "#/$defs/asset"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "asset": {
      "type": "object",
      "required": ["id", "path", "type", "size", "hash"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique asset identifier",
          "pattern": "^[a-zA-Z0-9_-]+$"
        },
        "path": {
          "description": "File path relative to category directory",
          "$ref": "https://cdx.dev/schemas/anchor.schema.json#/$defs/relativePath"
        },
        "type": {
          "description": "MIME type",
          "$ref": "https://cdx.dev/schemas/anchor.schema.json#/$defs/mimeType"
        },
        "size": {
          "type": "integer",
          "minimum": 0,
          "description": "File size in bytes"
        },
        "hash": {
          "description": "Content hash",
          "$ref": "https://cdx.dev/schemas/anchor.schema.json#/$defs/contentHash"
        },
        "aliasOf": {
          "type": "string",
          "description": "ID of asset this is an alias of (for deduplication)"
        },
        "metadata": {
          "type": "object",
          "description": "Type-specific metadata (image dimensions, font weight, etc.). Intentionally open: the shape is asset-type-specific and extensible, so unknown keys are allowed by design.",
          "additionalProperties": true
        },
        "license": {
          "$ref": "#/$defs/license"
        },
        "variants": {
          "type": "array",
          "description": "Resolution variants (for images)",
          "items": {
            "$ref": "#/$defs/imageVariant"
          }
        }
      },
      "additionalProperties": false
    },
    "imageVariant": {
      "type": "object",
      "required": ["path", "width", "size", "hash"],
      "properties": {
        "path": {
          "description": "Variant file path",
          "$ref": "https://cdx.dev/schemas/anchor.schema.json#/$defs/relativePath"
        },
        "width": {
          "type": "integer",
          "minimum": 1,
          "description": "Variant width in pixels"
        },
        "size": {
          "type": "integer",
          "minimum": 0,
          "description": "Variant file size in bytes"
        },
        "hash": {
          "description": "Content hash of the variant file, using the parent asset's hash algorithm. A renderer that selects a variant displays the variant, not the parent, so the variant carries its own integrity binding; it is verified on load (Asset Embedding §4.3) and attested transitively via the hash-pinned asset index (Security Extension §9.7).",
          "$ref": "https://cdx.dev/schemas/anchor.schema.json#/$defs/contentHash"
        }
      },
      "additionalProperties": false
    },
    "fontFamily": {
      "type": "object",
      "required": ["name", "fonts"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Font family name"
        },
        "fonts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "weight", "style"],
            "properties": {
              "id": {
                "type": "string",
                "description": "Reference to asset ID"
              },
              "weight": {
                "type": "integer",
                "minimum": 100,
                "maximum": 900
              },
              "style": {
                "type": "string",
                "enum": ["normal", "italic", "oblique"]
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "license": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "License name"
        },
        "url": {
          "type": "string",
          "format": "uri",
          "description": "License URL"
        }
      },
      "additionalProperties": false
    }
  }
}
