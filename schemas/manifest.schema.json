{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cdx.dev/schemas/manifest.schema.json",
  "title": "CDX Document Manifest",
  "description": "Schema for the manifest.json file in a CDX document",
  "type": "object",
  "required": ["cdx", "id", "state", "created", "modified", "content", "metadata"],
  "properties": {
    "cdx": {
      "type": "string",
      "description": "Specification version",
      "pattern": "^\\d+\\.\\d+$",
      "examples": ["0.1", "1.0"]
    },
    "id": {
      "type": "string",
      "description": "Content-addressable document identifier",
      "oneOf": [
        { "const": "pending" },
        { "$ref": "https://cdx.dev/schemas/anchor.schema.json#/$defs/contentHash" }
      ]
    },
    "state": {
      "type": "string",
      "description": "Document lifecycle state",
      "enum": ["draft", "review", "frozen", "published"]
    },
    "hashAlgorithm": {
      "type": "string",
      "description": "Hash algorithm used for document ID",
      "enum": ["sha256", "sha384", "sha512", "sha3-256", "sha3-512", "blake3"]
    },
    "created": {
      "type": "string",
      "description": "ISO 8601 creation timestamp",
      "format": "date-time"
    },
    "modified": {
      "type": "string",
      "description": "ISO 8601 last modification timestamp",
      "format": "date-time"
    },
    "content": {
      "$ref": "#/$defs/fileReference",
      "description": "Content layer reference"
    },
    "presentation": {
      "type": "array",
      "description": "Presentation layer references",
      "items": {
        "$ref": "#/$defs/presentationReference"
      }
    },
    "assets": {
      "type": "object",
      "description": "Asset manifest",
      "properties": {
        "images": { "$ref": "#/$defs/assetCategory" },
        "fonts": { "$ref": "#/$defs/assetCategory" },
        "embeds": { "$ref": "#/$defs/assetCategory" }
      },
      "additionalProperties": { "$ref": "#/$defs/assetCategory" }
    },
    "security": {
      "type": ["object", "null"],
      "description": "Security layer reference",
      "properties": {
        "signatures": {
          "description": "Path to signatures file",
          "anyOf": [
            { "$ref": "https://cdx.dev/schemas/anchor.schema.json#/$defs/relativePath" },
            { "type": "null" }
          ]
        },
        "encryption": {
          "description": "Path to encryption metadata",
          "anyOf": [
            { "$ref": "https://cdx.dev/schemas/anchor.schema.json#/$defs/relativePath" },
            { "type": "null" }
          ]
        },
        "accessControl": {
          "description": "Reference to the access-control policy file as a {path, hash}. Unlike the path-only signatures/encryption references, the policy's content hash is bound into the manifest projection, so a manifest-covering signature attests the policy (security extension section 9.9).",
          "anyOf": [
            { "$ref": "#/$defs/fileReference" },
            { "type": "null" }
          ]
        }
      },
      "additionalProperties": false
    },
    "extensions": {
      "type": "array",
      "description": "Active extension declarations",
      "items": {
        "$ref": "#/$defs/extension"
      }
    },
    "metadata": {
      "type": "object",
      "description": "Metadata references",
      "required": ["dublinCore"],
      "properties": {
        "dublinCore": {
          "description": "Path to Dublin Core metadata",
          "$ref": "https://cdx.dev/schemas/anchor.schema.json#/$defs/relativePath"
        },
        "jsonld": {
          "description": "Path to a document-level JSON-LD metadata file (semantic extension). Out-of-hash advisory data — referenced by path only, with no manifest hash.",
          "$ref": "https://cdx.dev/schemas/anchor.schema.json#/$defs/relativePath"
        },
        "custom": {
          "type": "object",
          "description": "Custom metadata references",
          "additionalProperties": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "phantoms": {
      "type": "object",
      "description": "Phantom layer reference (Phantom Extension)",
      "required": ["clusters"],
      "properties": {
        "clusters": {
          "description": "Path to phantom clusters file",
          "$ref": "https://cdx.dev/schemas/anchor.schema.json#/$defs/relativePath"
        }
      },
      "additionalProperties": false
    },
    "lineage": {
      "type": "object",
      "description": "Version history and parent reference",
      "properties": {
        "parent": {
          "description": "Document ID of parent version",
          "anyOf": [
            { "$ref": "https://cdx.dev/schemas/anchor.schema.json#/$defs/contentHash" },
            { "type": "null" }
          ]
        },
        "ancestors": {
          "type": "array",
          "description": "Chain of ancestor hashes (nearest first)",
          "items": { "$ref": "https://cdx.dev/schemas/anchor.schema.json#/$defs/contentHash" },
          "maxItems": 1024
        },
        "version": {
          "type": "integer",
          "minimum": 1,
          "description": "Sequential version number"
        },
        "depth": {
          "type": "integer",
          "minimum": 1,
          "description": "Generation number: 1 for the root document, incremented by 1 each generation (one more than the number of ancestor links). Advisory; recomputed on verification."
        },
        "branch": {
          "type": "string",
          "description": "Branch identifier"
        },
        "mergedFrom": {
          "type": "array",
          "description": "Document hashes merged into this version",
          "items": { "$ref": "https://cdx.dev/schemas/anchor.schema.json#/$defs/contentHash" },
          "maxItems": 1024
        },
        "note": {
          "type": "string",
          "description": "Description of changes from parent"
        }
      },
      "additionalProperties": false
    },
    "provenance": {
      "description": "Path to provenance record file",
      "$ref": "https://cdx.dev/schemas/anchor.schema.json#/$defs/relativePath"
    },
    "signaturePolicy": {
      "description": "Document signature policy: the required-signer set that binds the signature set against stripping and downgrade (Security Extension §3.12). Bound by the signed manifest projection (§9.7).",
      "$ref": "https://cdx.dev/schemas/anchor.schema.json#/$defs/signaturePolicy"
    },
    "profile": {
      "type": "string",
      "description": "Advisory profile declaration (e.g. \"simple\"). A non-normative hint identifying the profile the document targets; it never affects document validity, and consumers process the document as standard CDX regardless of the declared value (Manifest §4.18, Profiles). Not a conformance class — see Introduction §1.3."
    },
    "academic": {
      "type": "object",
      "description": "Academic Extension manifest configuration (e.g. the numbering config path). The extension owns this object's shape, so it is left open here."
    },
    "semantic": {
      "type": "object",
      "description": "Semantic Extension manifest configuration (e.g. bibliography/glossary file paths). The extension owns this object's shape, so it is left open here."
    },
    "legal": {
      "type": "object",
      "description": "Legal Extension manifest configuration (e.g. citation style, jurisdiction). The extension owns this object's shape, so it is left open here."
    },
    "collaboration": {
      "type": "object",
      "description": "Collaboration Extension manifest configuration (e.g. comments/changes file paths). The extension owns this object's shape, so it is left open here."
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "description": "A `pending` id (deferred document-id computation) is valid only in the `draft` state; once the document is frozen or published its id is the computed content hash (State Machine §5.3).",
      "if": {
        "required": ["id"],
        "properties": { "id": { "const": "pending" } }
      },
      "then": {
        "properties": { "state": { "const": "draft" } }
      }
    }
  ],
  "$defs": {
    "fileReference": {
      "type": "object",
      "required": ["path", "hash"],
      "properties": {
        "path": {
          "description": "Relative path within archive",
          "$ref": "https://cdx.dev/schemas/anchor.schema.json#/$defs/relativePath"
        },
        "hash": {
          "description": "Hash of file contents",
          "$ref": "https://cdx.dev/schemas/anchor.schema.json#/$defs/contentHash"
        },
        "compression": {
          "type": "string",
          "description": "Compression method used",
          "enum": ["none", "deflate", "zstd"]
        },
        "merkleRoot": {
          "description": "Merkle root of content blocks",
          "$ref": "https://cdx.dev/schemas/anchor.schema.json#/$defs/contentHash"
        },
        "blockCount": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of content blocks"
        }
      },
      "additionalProperties": false
    },
    "presentationReference": {
      "type": "object",
      "required": ["type", "path", "hash"],
      "properties": {
        "type": {
          "type": "string",
          "description": "Presentation type identifier. `precise` references a precise-layout file (presentation/layouts/*.json, precise-layout.schema.json, whose own discriminator is `presentationType`); the reactive types reference a presentation.schema.json file. Declaring a precise layout here binds its file `hash` into the manifest projection (Security Extension section 9.7), so a frozen or published document's precise layout is tamper-evident under a manifest-covering signature.",
          "enum": ["paginated", "continuous", "responsive", "precise"]
        },
        "path": {
          "description": "Relative path within archive",
          "$ref": "https://cdx.dev/schemas/anchor.schema.json#/$defs/relativePath"
        },
        "hash": {
          "description": "Hash of file contents",
          "$ref": "https://cdx.dev/schemas/anchor.schema.json#/$defs/contentHash"
        },
        "default": {
          "type": "boolean",
          "description": "Whether this is the default presentation"
        },
        "contentHash": {
          "description": "Content hash when presentation was generated",
          "$ref": "https://cdx.dev/schemas/anchor.schema.json#/$defs/contentHash"
        },
        "generated": {
          "type": "string",
          "format": "date-time",
          "description": "When presentation was generated"
        }
      },
      "additionalProperties": false
    },
    "assetCategory": {
      "type": "object",
      "required": ["count", "totalSize", "index", "hash"],
      "properties": {
        "count": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of assets in category"
        },
        "totalSize": {
          "type": "integer",
          "minimum": 0,
          "description": "Total size in bytes"
        },
        "index": {
          "description": "Path to index file",
          "$ref": "https://cdx.dev/schemas/anchor.schema.json#/$defs/relativePath"
        },
        "hash": {
          "description": "Content hash of the index file. Hash-pins the category's asset index — which carries every asset's (and variant's) hash — so that binding this one hash into the signed manifest projection (Security Extension §9.7) transitively attests the whole category, including out-of-content assets such as fonts and image variants.",
          "$ref": "https://cdx.dev/schemas/anchor.schema.json#/$defs/contentHash"
        }
      },
      "additionalProperties": false
    },
    "extension": {
      "type": "object",
      "required": ["id", "version", "required"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Extension identifier"
        },
        "version": {
          "type": "string",
          "description": "Extension version"
        },
        "required": {
          "type": "boolean",
          "description": "Whether extension is required for correct rendering"
        },
        "config": {
          "type": "object",
          "description": "Extension-specific configuration paths or inline settings",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    }
  }
}
