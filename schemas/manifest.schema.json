{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cdx.dev/schemas/manifest.schema.json",
  "title": "CDX Document Manifest",
  "description": "Schema for the manifest.json file in a CDX document",
  "type": "object",
  "required": ["cdx", "id", "state", "created", "modified", "content", "metadata"],
  "properties": {
    "cdx": {
      "type": "string",
      "description": "Specification version",
      "pattern": "^\\d+\\.\\d+$",
      "examples": ["0.1", "1.0"]
    },
    "id": {
      "type": "string",
      "description": "Content-addressable document identifier",
      "oneOf": [
        { "const": "pending" },
        { "$ref": "https://cdx.dev/schemas/anchor.schema.json#/$defs/contentHash" }
      ]
    },
    "state": {
      "type": "string",
      "description": "Document lifecycle state",
      "enum": ["draft", "review", "frozen", "published"]
    },
    "hashAlgorithm": {
      "type": "string",
      "description": "Hash algorithm used for document ID",
      "enum": ["sha256", "sha384", "sha512", "sha3-256", "sha3-512", "blake3"],
      "default": "sha256"
    },
    "created": {
      "type": "string",
      "description": "ISO 8601 creation timestamp",
      "format": "date-time"
    },
    "modified": {
      "type": "string",
      "description": "ISO 8601 last modification timestamp",
      "format": "date-time"
    },
    "content": {
      "$ref": "#/$defs/fileReference",
      "description": "Content layer reference"
    },
    "presentation": {
      "type": "array",
      "description": "Presentation layer references",
      "items": {
        "$ref": "#/$defs/presentationReference"
      }
    },
    "assets": {
      "type": "object",
      "description": "Asset manifest",
      "properties": {
        "images": { "$ref": "#/$defs/assetCategory" },
        "fonts": { "$ref": "#/$defs/assetCategory" },
        "embeds": { "$ref": "#/$defs/assetCategory" }
      },
      "additionalProperties": { "$ref": "#/$defs/assetCategory" }
    },
    "security": {
      "type": ["object", "null"],
      "description": "Security layer reference",
      "properties": {
        "signatures": {
          "description": "Path to signatures file",
          "anyOf": [
            { "$ref": "https://cdx.dev/schemas/anchor.schema.json#/$defs/relativePath" },
            { "type": "null" }
          ]
        },
        "encryption": {
          "description": "Path to encryption metadata",
          "anyOf": [
            { "$ref": "https://cdx.dev/schemas/anchor.schema.json#/$defs/relativePath" },
            { "type": "null" }
          ]
        }
      }
    },
    "extensions": {
      "type": "array",
      "description": "Active extension declarations",
      "items": {
        "$ref": "#/$defs/extension"
      }
    },
    "metadata": {
      "type": "object",
      "description": "Metadata references",
      "required": ["dublinCore"],
      "properties": {
        "dublinCore": {
          "description": "Path to Dublin Core metadata",
          "$ref": "https://cdx.dev/schemas/anchor.schema.json#/$defs/relativePath"
        },
        "custom": {
          "type": "object",
          "description": "Custom metadata references",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "phantoms": {
      "type": "object",
      "description": "Phantom layer reference (Phantom Extension)",
      "required": ["clusters"],
      "properties": {
        "clusters": {
          "description": "Path to phantom clusters file",
          "$ref": "https://cdx.dev/schemas/anchor.schema.json#/$defs/relativePath"
        }
      }
    },
    "lineage": {
      "type": "object",
      "description": "Version history and parent reference",
      "properties": {
        "parent": {
          "description": "Document ID of parent version",
          "anyOf": [
            { "$ref": "https://cdx.dev/schemas/anchor.schema.json#/$defs/contentHash" },
            { "type": "null" }
          ]
        },
        "ancestors": {
          "type": "array",
          "description": "Chain of ancestor hashes (nearest first)",
          "items": { "$ref": "https://cdx.dev/schemas/anchor.schema.json#/$defs/contentHash" },
          "maxItems": 1024
        },
        "version": {
          "type": "integer",
          "minimum": 1,
          "description": "Sequential version number"
        },
        "depth": {
          "type": "integer",
          "minimum": 1,
          "description": "Distance from root document"
        },
        "branch": {
          "type": "string",
          "description": "Branch identifier"
        },
        "mergedFrom": {
          "type": "array",
          "description": "Document hashes merged into this version",
          "items": { "$ref": "https://cdx.dev/schemas/anchor.schema.json#/$defs/contentHash" },
          "maxItems": 1024
        },
        "note": {
          "type": "string",
          "description": "Description of changes from parent"
        }
      }
    },
    "provenance": {
      "description": "Path to provenance record file",
      "$ref": "https://cdx.dev/schemas/anchor.schema.json#/$defs/relativePath"
    },
    "signaturePolicy": {
      "description": "Document signature policy: the required-signer set that binds the signature set against stripping and downgrade (Security Extension §3.12). Bound by the signed manifest projection (§9.7).",
      "$ref": "https://cdx.dev/schemas/anchor.schema.json#/$defs/signaturePolicy"
    }
  },
  "$defs": {
    "fileReference": {
      "type": "object",
      "required": ["path", "hash"],
      "properties": {
        "path": {
          "description": "Relative path within archive",
          "$ref": "https://cdx.dev/schemas/anchor.schema.json#/$defs/relativePath"
        },
        "hash": {
          "description": "Hash of file contents",
          "$ref": "https://cdx.dev/schemas/anchor.schema.json#/$defs/contentHash"
        },
        "compression": {
          "type": "string",
          "description": "Compression method used",
          "enum": ["none", "deflate", "zstd"]
        },
        "merkleRoot": {
          "description": "Merkle root of content blocks",
          "$ref": "https://cdx.dev/schemas/anchor.schema.json#/$defs/contentHash"
        },
        "blockCount": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of content blocks"
        }
      }
    },
    "presentationReference": {
      "type": "object",
      "required": ["type", "path", "hash"],
      "properties": {
        "type": {
          "type": "string",
          "description": "Presentation type identifier",
          "enum": ["paginated", "continuous", "responsive"]
        },
        "path": {
          "description": "Relative path within archive",
          "$ref": "https://cdx.dev/schemas/anchor.schema.json#/$defs/relativePath"
        },
        "hash": {
          "description": "Hash of file contents",
          "$ref": "https://cdx.dev/schemas/anchor.schema.json#/$defs/contentHash"
        },
        "default": {
          "type": "boolean",
          "description": "Whether this is the default presentation"
        },
        "contentHash": {
          "description": "Content hash when presentation was generated",
          "$ref": "https://cdx.dev/schemas/anchor.schema.json#/$defs/contentHash"
        },
        "generated": {
          "type": "string",
          "format": "date-time",
          "description": "When presentation was generated"
        }
      }
    },
    "assetCategory": {
      "type": "object",
      "required": ["count", "totalSize", "index"],
      "properties": {
        "count": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of assets in category"
        },
        "totalSize": {
          "type": "integer",
          "minimum": 0,
          "description": "Total size in bytes"
        },
        "index": {
          "description": "Path to index file",
          "$ref": "https://cdx.dev/schemas/anchor.schema.json#/$defs/relativePath"
        }
      }
    },
    "extension": {
      "type": "object",
      "required": ["id", "version", "required"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Extension identifier"
        },
        "version": {
          "type": "string",
          "description": "Extension version"
        },
        "required": {
          "type": "boolean",
          "description": "Whether extension is required for correct rendering"
        },
        "config": {
          "type": "object",
          "description": "Extension-specific configuration paths or inline settings",
          "additionalProperties": true
        }
      }
    }
  }
}
